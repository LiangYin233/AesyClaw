{
  "name": "aesyclaw",
  "version": "0.1.0",
  "description": "A lightweight AI Agent framework",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:webui": "cd webui && npm run build",
    "start": "node bin/aesyclaw.js start",
    "start:gateway": "node bin/aesyclaw.js gateway",
    "start:webui": "node bin/aesyclaw.js webui",
    "start:api": "node bin/aesyclaw.js api",
    "start:all": "node bin/aesyclaw.js all",
    "stop": "node bin/aesyclaw.js stop",
    "restart": "node bin/aesyclaw.js restart",
    "status": "node bin/aesyclaw.js status",
    "dev": "tsx watch src/cli.ts",
    "dev:webui": "cd webui && npm run dev",
    "gateway": "tsx --no-cache src/cli.ts gateway",
    "launcher": "powershell -ExecutionPolicy Bypass -File launcher.ps1",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.16.0",
    "yaml": "^2.3.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  }
}
