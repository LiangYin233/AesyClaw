{
  "name": "aesyclaw",
  "version": "0.1.0",
  "description": "A lightweight AI Agent framework",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:webui": "cd webui && npm run build",
    "start": "node dist/cli.js",
    "dev": "tsx watch src/cli.ts",
    "dev:webui": "cd webui && npm run dev",
    "gateway": "tsx --no-cache src/cli.ts gateway",
    "launcher": "powershell -ExecutionPolicy Bypass -File launcher.ps1"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "ws": "^8.16.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
