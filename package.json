{
    "name": "aesyclaw",
    "version": "1.0.0",
    "packageManager": "yarn@1.22.22",
    "type": "module",
    "main": "dist/src/index.js",
    "scripts": {
        "dev": "chcp 65001 && tsx watch src/index.ts",
        "start": "tsx src/index.ts",
        "build": "tsc && tsc-alias",
        "format": "prettier --write \"src/**/*.ts\" \"plugins/**/*.ts\" package.json eslint.config.mjs",
        "lint": "eslint \"src/**/*.ts\" \"plugins/**/*.ts\"",
        "postinstall": "npm rebuild better-sqlite3",
        "rebuild:native": "npm rebuild better-sqlite3"
    },
    "dependencies": {
        "@mariozechner/pi-agent-core": "^0.68.1",
        "@mariozechner/pi-ai": "^0.68.1",
        "@modelcontextprotocol/sdk": "^1.12.0",
        "@sinclair/typebox": "^0.34.0",
        "better-sqlite3": "^12.9.0",
        "c12": "^4.0.0-beta.4",
        "defu": "^6.1.7",
        "jiti": "^2.6.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.6.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "eslint": "^10.2.0",
        "globals": "^17.5.0",
        "prettier": "^3.6.2",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
