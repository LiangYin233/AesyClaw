{
  "name": "aesyclaw",
  "version": "0.6.5",
  "description": "A lightweight AI Agent framework",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.plugins.json",
    "build:webui": "cd webui && npm run build",
    "lint": "eslint \"src/**/*.ts\" \"plugins/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"plugins/**/*.ts\" --fix",
    "start": "tsx src/cli.ts start",
    "start:gateway": "tsx src/cli.ts gateway",
    "start:webui": "tsx src/cli.ts start webui",
    "start:all": "tsx src/cli.ts start all",
    "status": "tsx src/cli.ts status",
    "dev": "tsx watch src/cli.ts gateway",
    "dev:webui": "cd webui && npm run dev",
    "gateway": "tsx src/cli.ts gateway"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/form-data": "^2.2.1",
    "cron-parser": "^5.5.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "smol-toml": "^1.4.2",
    "sqlite3": "^5.1.7",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.5.10",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
