{
  "name": "aesyclaw",
  "version": "2026.5.2",
  "description": "An extensible AI Agent runtime platform",
  "private": true,
  "workspaces": [
    "extensions/*",
    "web"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "yarn build && node --import tsx src/index.ts",
    "web:dev": "yarn workspace aesyclaw-webui dev",
    "web:build": "yarn workspace aesyclaw-webui build",
    "build": "yarn workspace aesyclaw-webui build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tools.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@mariozechner/pi-agent-core": "^0.70.0",
    "@mariozechner/pi-ai": "^0.70.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sinclair/typebox": "^0.34.0",
    "conf": "^15.1.0",
    "front-matter": "^4.0.2",
    "hono": "^4.12.15",
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
