{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "primevue": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@primevue/mcp"
      ]
    },
    "NapCat - API 文档": {
      "type": "local",
      "enabled": true,
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "apifox-mcp-server@latest",
        "--site-id=5348325"
      ]
    },
    "MiniMax": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "environment": {
        "MINIMAX_API_KEY": "sk-cp-WhXsqfR3snFi6maurdoPifmtCOPyE-s4oXDlSuAr9QgUeTjeLFscyN-1mslAsDjGZO0w7K3kqyhztTLSa88wRVJUNvzbLPRB4NutSjU7fCBGVlV-fc-a1_8",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    }
  }
}